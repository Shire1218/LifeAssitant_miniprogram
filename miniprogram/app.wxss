/* ========================================
   生活助手 - 全局设计规范
   ========================================
   色彩系统:
     主色: #1677ff (蓝)
     收入: #00b96b (绿)
     支出: #e84749 (红)
     辅助: #f59e0b (橙)
   背景:
     页面: #f0f2f5
     卡片: #ffffff
   文字:
     主要: #1a1a2e
     次要: #4a4a68
     辅助: #8c8ca1
     占位: #c8c8d4
   圆角:
     小: 12rpx  中: 20rpx  大: 28rpx  超大: 36rpx
   阴影:
     卡片: 0 4rpx 20rpx rgba(0,0,0,0.04)
     浮层: 0 8rpx 32rpx rgba(0,0,0,0.08)
   ======================================== */

page {
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 24rpx;
}

.page-bg {
  min-height: 100vh;
  background-color: #f0f2f5;
}

/* ---- 卡片 ---- */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* ---- 按钮 ---- */
.btn-primary {
  background: linear-gradient(135deg, #1677ff 0%, #4f9cff 100%);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx 36rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.25);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.btn-danger {
  background: linear-gradient(135deg, #e84749 0%, #ff6b6b 100%);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx 36rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(232, 71, 73, 0.25);
}

.btn-danger::after {
  border: none;
}

.btn-danger:active {
  opacity: 0.88;
  transform: scale(0.98);
}

/* ---- 文字颜色 ---- */
.text-income {
  color: #00b96b;
}

.text-expense {
  color: #e84749;
}

.text-primary {
  color: #1677ff;
}

.text-auxiliary {
  color: #f59e0b;
}

.text-gray {
  color: #8c8ca1;
}

/* ---- 文字大小 ---- */
.text-small {
  font-size: 24rpx;
}

.text-large {
  font-size: 36rpx;
  font-weight: 700;
}

/* ---- Flex 布局 ---- */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.flex-wrap {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

/* ---- 间距 ---- */
.mt-12 {
  margin-top: 12rpx;
}

.mt-24 {
  margin-top: 24rpx;
}

.mb-12 {
  margin-bottom: 12rpx;
}

.mb-24 {
  margin-bottom: 24rpx;
}

/* ---- 分割线 ---- */
.divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, #e8e8f0, transparent);
  margin: 24rpx 0;
}

/* ---- 空状态 ---- */
.empty-tip {
  text-align: center;
  color: #8c8ca1;
  padding: 80rpx 0;
  font-size: 28rpx;
}

/* ---- 标签 ---- */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background-color: rgba(22, 119, 255, 0.08);
  color: #1677ff;
}

.tag-success {
  background-color: rgba(0, 185, 107, 0.08);
  color: #00b96b;
}

.tag-danger {
  background-color: rgba(232, 71, 73, 0.08);
  color: #e84749;
}

.tag-auxiliary {
  background-color: rgba(245, 158, 11, 0.08);
  color: #f59e0b;
}

/* ---- 输入框 ---- */
.input-common {
  background-color: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-common:focus {
  border-color: #1677ff;
  background-color: #ffffff;
}
