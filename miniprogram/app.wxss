page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.page-bg {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: #1677ff;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-danger {
  background-color: #f5222d;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
}

.btn-danger::after {
  border: none;
}

.btn-danger:active {
  opacity: 0.8;
}

.text-income {
  color: #52c41a;
}

.text-expense {
  color: #f5222d;
}

.text-primary {
  color: #1677ff;
}

.text-auxiliary {
  color: #faad14;
}

.text-gray {
  color: #999999;
}

.text-small {
  font-size: 24rpx;
}

.text-large {
  font-size: 36rpx;
  font-weight: 600;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.flex-wrap {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.mt-12 {
  margin-top: 12rpx;
}

.mt-24 {
  margin-top: 24rpx;
}

.mb-12 {
  margin-bottom: 12rpx;
}

.mb-24 {
  margin-bottom: 24rpx;
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 24rpx 0;
}

.empty-tip {
  text-align: center;
  color: #999999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background-color: rgba(22, 119, 255, 0.1);
  color: #1677ff;
}

.tag-success {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.tag-danger {
  background-color: rgba(245, 34, 45, 0.1);
  color: #f5222d;
}

.tag-auxiliary {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.input-common {
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}
