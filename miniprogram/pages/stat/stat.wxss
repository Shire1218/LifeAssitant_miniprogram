.range-switcher {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.switch-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.25s;
}

.switch-btn.active {
  background-color: #1677ff;
  color: #ffffff;
  font-weight: 600;
}

.type-switcher {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.25s;
}

.type-btn.active {
  background-color: #1677ff;
  color: #ffffff;
  font-weight: 600;
}

.period-row {
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.period-picker {
  flex: 1;
}

.picker-display {
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  background-color: #ffffff;
  align-items: center;
  justify-content: space-between;
}

.picker-display text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.total-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.total-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.total-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
}

.chart-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pie-canvas {
  width: 400rpx;
  height: 400rpx;
}

.empty-chart {
  padding: 80rpx 0;
  text-align: center;
}

.empty-chart-text {
  font-size: 28rpx;
  color: #999999;
}

.legend-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.legend-item:last-child {
  border-bottom: none;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.legend-name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.legend-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.legend-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.legend-percent {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}
