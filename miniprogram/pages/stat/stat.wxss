/* ========================================
   统计页面样式
   ======================================== */

page {
  height: auto;
  overflow-y: auto;
}

.page-bg {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---- 切换器通用 ---- */
.range-switcher {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.switch-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #8c8ca1;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.switch-btn.active {
  background: linear-gradient(135deg, #1677ff 0%, #4f9cff 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.25);
}

.type-switcher {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #8c8ca1;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.type-btn.active {
  background: linear-gradient(135deg, #1677ff 0%, #4f9cff 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.25);
}

/* ---- 时间选择器 ---- */
.period-row {
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.period-picker {
  flex: 1;
}

.picker-display {
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s;
}

.picker-display:active {
  background-color: #f5f6fa;
}

.picker-display text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.picker-arrow {
  font-size: 32rpx;
  color: #c8c8d4;
}

/* ---- 总额卡片 ---- */
.total-card {
  background: linear-gradient(145deg, #1677ff 0%, #3d8bff 40%, #6aabff 100%);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(22, 119, 255, 0.3);
}

.total-card-decor {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.total-card-decor-1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -30rpx;
}

.total-card-decor-2 {
  width: 140rpx;
  height: 140rpx;
  bottom: -40rpx;
  left: -20rpx;
}

.total-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 16rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}

.total-value-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  position: relative;
  z-index: 1;
}

.total-currency {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.85);
  margin-right: 8rpx;
}

.total-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1rpx;
}

/* ---- 图表卡片 ---- */
.chart-card {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.chart-card-title {
  width: 100%;
  margin-bottom: 24rpx;
}

.chart-title-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.pie-canvas {
  width: 420rpx;
  height: 420rpx;
}

.empty-chart {
  padding: 60rpx 0 80rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-chart-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f0f2f5, #e8eaf0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty-chart-icon {
  font-size: 52rpx;
}

.empty-chart-text {
  font-size: 26rpx;
  color: #8c8ca1;
  font-weight: 500;
}

/* ---- 图例卡片 ---- */
.legend-card {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.legend-header {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f5;
  margin-bottom: 8rpx;
}

.legend-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 12rpx;
  border-bottom: 1rpx solid #f5f6fa;
  transition: background-color 0.15s;
}

.legend-item:last-child {
  border-bottom: none;
}

.legend-item:active {
  background-color: #fafafe;
  border-radius: 12rpx;
}

.legend-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.legend-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.legend-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.legend-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.legend-percent-badge {
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  min-width: 80rpx;
  text-align: center;
}

.legend-percent {
  font-size: 22rpx;
  font-weight: 600;
}
