.header-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.date-picker {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.date-text {
  font-size: 26rpx;
  color: #666666;
}

.date-arrow {
  font-size: 28rpx;
  color: #999999;
  margin-left: 8rpx;
}

.nutrition-summary {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nutrition-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1677ff;
}

.nutrition-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.meal-type-tabs {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 12rpx 8rpx;
  margin-bottom: 20rpx;
  justify-content: space-around;
}

.meal-type-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  transition: all 0.2s;
}

.meal-type-tab.active {
  background-color: rgba(22, 119, 255, 0.08);
}

.meal-type-emoji {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.meal-type-label {
  font-size: 24rpx;
  color: #666666;
}

.meal-type-tab.active .meal-type-label {
  color: #1677ff;
  font-weight: 600;
}

.search-bar {
  margin-bottom: 16rpx;
}

.search-input {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.category-scroll {
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 4rpx 0;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
  min-width: 100rpx;
  transition: all 0.2s;
  flex-shrink: 0;
}

.category-item.active {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.category-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.category-label {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
}

.food-list {
  padding-bottom: 180rpx;
}

.empty-food {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-food-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-food-text {
  font-size: 28rpx;
  color: #999999;
}

.food-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.food-card:active {
  transform: scale(0.98);
}

.food-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.food-tags {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.food-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-category {
  background-color: rgba(22, 119, 255, 0.08);
  color: #1677ff;
}

.tag-calories {
  background-color: rgba(250, 173, 20, 0.1);
  color: #fa8c16;
}

.food-nutrition {
  margin-top: 4rpx;
}

.nutrition-text {
  font-size: 22rpx;
  color: #999999;
}

.food-price-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.food-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.add-cart-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
}

.add-cart-btn text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 300;
}

.cart-bar {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx;
  background-color: #1677ff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
  z-index: 100;
}

.cart-icon-wrapper {
  position: relative;
  margin-right: 16rpx;
}

.cart-icon {
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart-total {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.cart-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2rpx;
}

.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.cart-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.cart-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.clear-cart-btn {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  background-color: rgba(245, 34, 45, 0.1);
  font-size: 24rpx;
  color: #f5222d;
}

.cart-scroll {
  flex: 1;
  min-height: 0;
  padding: 16rpx 32rpx;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-cart-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-cart-text {
  font-size: 28rpx;
  color: #999999;
}

.cart-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-item-info {
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.cart-item-portion {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
  display: block;
}

.cart-item-action {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.cart-qty-control {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.qty-btn text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 600;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  min-width: 40rpx;
  text-align: center;
}

.cart-item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff4d4f;
  min-width: 80rpx;
  text-align: right;
}

.cart-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.cart-summary {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-label {
  font-size: 28rpx;
  color: #666666;
}

.summary-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.submit-order-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-order-btn:active {
  opacity: 0.85;
}

.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.detail-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.detail-header {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.detail-category {
  padding: 6rpx 16rpx;
  background-color: rgba(22, 119, 255, 0.08);
  color: #1677ff;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-nutrition-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 24rpx 32rpx;
  background-color: #f9f9f9;
  margin: 0 32rpx;
  border-radius: 16rpx;
}

.detail-nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-nutrition-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1677ff;
}

.detail-nutrition-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.detail-portion {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.portion-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.portion-control {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.portion-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.portion-btn text {
  font-size: 32rpx;
  color: #666666;
  font-weight: 600;
}

.portion-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  min-width: 60rpx;
  text-align: center;
}

.detail-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.detail-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.detail-add-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-add-btn:active {
  opacity: 0.85;
}

.diet-record-section {
  margin-top: 24rpx;
  padding-bottom: 120rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.empty-record {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-record-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.empty-record-text {
  font-size: 26rpx;
  color: #999999;
}

.record-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-detail {
  font-size: 26rpx;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.record-nutrition {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.record-cal {
  font-size: 22rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.record-nut {
  font-size: 20rpx;
  color: #999999;
}

.record-delete-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(245, 34, 45, 0.1);
  margin-left: 12rpx;
  flex-shrink: 0;
}

.record-delete-btn text {
  font-size: 20rpx;
  color: #f5222d;
}
