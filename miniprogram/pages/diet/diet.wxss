.header-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.date-picker {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.date-text {
  font-size: 26rpx;
  color: #666666;
}

.date-arrow {
  font-size: 28rpx;
  color: #999999;
  margin-left: 8rpx;
}

.meal-tabs {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 12rpx 8rpx;
  margin-bottom: 24rpx;
  justify-content: space-around;
}

.meal-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  transition: all 0.2s;
}

.meal-tab.active {
  background-color: rgba(22, 119, 255, 0.08);
}

.meal-emoji {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.meal-name {
  font-size: 24rpx;
  color: #666666;
}

.meal-tab.active .meal-name {
  color: #1677ff;
  font-weight: 600;
}

.diet-list {
  padding-bottom: 160rpx;
}

.empty-meal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-meal-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-meal-text {
  font-size: 28rpx;
  color: #999999;
}

.diet-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.diet-card-header {
  margin-bottom: 12rpx;
}

.diet-text {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.diet-delete-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(245, 34, 45, 0.1);
  margin-left: 16rpx;
}

.diet-delete-btn text {
  font-size: 22rpx;
  color: #f5222d;
}

.diet-images {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}

.diet-img {
  width: calc((100% - 16rpx) / 3);
  height: 200rpx;
  border-radius: 12rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  gap: 16rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  gap: 8rpx;
}

.action-record {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
}

.action-quick {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.action-icon {
  font-size: 32rpx;
}

.action-label {
  font-size: 28rpx;
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-title-bar {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.modal-close-btn text {
  font-size: 28rpx;
  color: #999999;
}

.modal-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.meal-type-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.meal-type-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  border: 3rpx solid #f0f0f0;
  transition: all 0.2s;
}

.meal-type-card.active {
  border-color: #1677ff;
  background-color: rgba(22, 119, 255, 0.05);
}

.meal-type-emoji {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.meal-type-label {
  font-size: 24rpx;
  color: #666666;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.form-textarea {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.image-upload-area {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.uploaded-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.uploaded-image image {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 3rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999999;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f5f5;
}

.submit-btn {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn:active {
  opacity: 0.85;
}
