/* ============================================
   饮食管理页面 - 精简版样式
   仅保留名称和分类两个核心属性
   ============================================ */

/* ---------- 页面容器 ---------- */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f6fa;
  position: relative;
}

/* ---------- 状态栏 ---------- */
.status-bar {
  background: #1677ff;
  flex-shrink: 0;
}

/* ---------- 顶部导航栏（仅标题） ---------- */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx 24rpx;
  background: #1677ff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

/* ---------- 二级页面切换 Tab ---------- */
.page-tabs {
  display: flex;
  padding: 0 32rpx;
  background: #1677ff;
  padding-bottom: 20rpx;
}

.page-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
}

.page-tab.active {
  color: #ffffff;
}

.page-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 6rpx;
  background: #ffffff;
  border-radius: 999rpx;
}

/* ---------- 页面内容区 ---------- */
.page-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 280rpx;
}

.page-view {
  display: none;
}

.page-view.active {
  display: block;
}

/* ---------- 日期选择器（记录页） ---------- */
.date-section {
  padding: 24rpx 32rpx 0;
}

.date-picker-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.date-picker-icon {
  font-size: 32rpx;
}

.date-picker-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.date-picker-arrow {
  font-size: 28rpx;
  color: #8c8ea4;
}

/* ---------- 餐类切换 ---------- */
.meal-tabs {
  white-space: nowrap;
  padding: 24rpx 32rpx;
}

.meal-tab {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 36rpx;
  background: #ffffff;
  border-radius: 999rpx;
  margin-right: 16rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.meal-tab.active {
  background: rgba(22, 119, 255, 0.08);
  border-color: #1677ff;
}

.meal-tab-emoji {
  font-size: 36rpx;
}

.meal-tab-label {
  font-size: 28rpx;
  color: #555770;
  white-space: nowrap;
}

.meal-tab.active .meal-tab-label {
  color: #1677ff;
  font-weight: 600;
}

/* ---------- 搜索栏 ---------- */
.search-section {
  padding: 0 32rpx 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
  background: transparent;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f2f5;
  border-radius: 50%;
  font-size: 24rpx;
  color: #8c8ea4;
  flex-shrink: 0;
}

/* ---------- 双栏布局 ---------- */
.dual-layout {
  display: flex;
  height: 800rpx;
  margin: 0 32rpx;
  background: #ffffff;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

/* 左侧分类导航 */
.category-sidebar {
  width: 176rpx;
  background: #f8f9fb;
  flex-shrink: 0;
  height: 100%;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  gap: 8rpx;
  position: relative;
  border-left: 6rpx solid transparent;
}

.category-item.active {
  background: #ffffff;
  border-left-color: #1677ff;
}

.cat-icon {
  font-size: 48rpx;
}

.cat-label {
  font-size: 22rpx;
  color: #555770;
  text-align: center;
  line-height: 1.2;
}

.category-item.active .cat-label {
  color: #1677ff;
  font-weight: 600;
}

/* 右侧菜品列表 */
.food-panel {
  flex: 1;
  height: 100%;
  padding: 24rpx;
}

.food-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.food-panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.add-food-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.add-food-btn:active {
  opacity: 0.85;
}

.add-food-btn text {
  color: #ffffff;
}

/* 菜品卡片 */
.food-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
}

.food-card:active {
  opacity: 0.85;
}

.food-info {
  flex: 1;
  min-width: 0;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-category {
  background: rgba(22, 119, 255, 0.08);
  color: #1677ff;
}

.food-card-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.food-action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.food-action-btn text {
  font-size: 28rpx;
}

.food-edit-btn {
  background: rgba(250, 173, 20, 0.1);
}

.food-edit-btn text {
  color: #d48806;
}

.food-del-btn {
  background: rgba(255, 77, 79, 0.1);
}

.food-del-btn text {
  color: #ff4d4f;
}

.food-del-btn:active {
  background: #ff4d4f;
}

.food-del-btn:active text {
  color: #ffffff;
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.3);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.add-btn text {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 300;
}

.add-btn:active {
  opacity: 0.8;
}

/* ---------- 底部购物车栏（始终显示） ---------- */
.cart-bar {
  position: fixed;
  bottom: 240rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.12);
  z-index: 200;
}

.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f2f5;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.cart-icon-text {
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart-hint {
  font-size: 26rpx;
  color: #555770;
  font-weight: 500;
}

.cart-checkout {
  padding: 18rpx 40rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
}

.cart-checkout:active {
  opacity: 0.85;
}

/* ---------- 遮罩层 ---------- */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 500;
}

/* ---------- 底部弹出面板 ---------- */
.bottom-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 60vh;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  z-index: 600;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.bottom-sheet.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #e8e9f0;
  border-radius: 999rpx;
  margin: 20rpx auto 0;
  flex-shrink: 0;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx 24rpx;
  border-bottom: 2rpx solid #f0f1f5;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.sheet-clear-btn {
  padding: 8rpx 28rpx;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 999rpx;
}

.sheet-clear-btn text {
  font-size: 24rpx;
  color: #ff4d4f;
}

.sheet-body {
  flex: 1;
  padding: 24rpx 40rpx;
  min-height: 200rpx;
}

.sheet-footer {
  padding: 32rpx 40rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f0f1f5;
}

/* 购物车列表项 */
.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f0f1f5;
}

.cart-item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a2e;
  display: block;
}

.cart-item-portion {
  font-size: 22rpx;
  color: #8c8ea4;
  margin-top: 4rpx;
  display: block;
}

.cart-item-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

/* 数量控制器 */
.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
  border: 3rpx solid #1677ff;
}

.qty-btn text {
  font-size: 32rpx;
  color: #1677ff;
  font-weight: 600;
}

.qty-btn.minus {
  border-color: #e8e9f0;
}

.qty-btn.minus text {
  color: #555770;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  min-width: 40rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.3);
}

.submit-btn:active {
  opacity: 0.85;
}

/* ---------- 结算确认面板 ---------- */
.checkout-summary {
  text-align: center;
  padding: 24rpx 0 40rpx;
}

.checkout-summary-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.checkout-meal-section {
  padding: 0 0 32rpx;
}

.checkout-meal-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #555770;
  margin-bottom: 24rpx;
}

.checkout-meal-grid {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.checkout-meal-item {
  flex: 1;
  min-width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 16rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
  border: 3rpx solid transparent;
}

.checkout-meal-item.active {
  background: rgba(22, 119, 255, 0.06);
  border-color: #1677ff;
}

.checkout-meal-emoji {
  font-size: 48rpx;
}

.checkout-meal-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #555770;
}

.checkout-meal-item.active .checkout-meal-name {
  color: #1677ff;
}

.checkout-btn-row {
  display: flex;
  gap: 24rpx;
}

/* ---------- 饮食记录 - 餐类标签 ---------- */
.record-meal-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.record-meal-tag.breakfast {
  background: rgba(250, 173, 20, 0.1);
  color: #d48806;
}

.record-meal-tag.lunch {
  background: rgba(22, 119, 255, 0.08);
  color: #1677ff;
}

.record-meal-tag.dinner {
  background: rgba(114, 46, 209, 0.08);
  color: '#722ed1';
}

.record-meal-tag.snack {
  background: rgba(82, 196, 26, 0.1);
  color: '#52c41a';
}

/* ---------- 今日饮食记录 ---------- */
.records-section {
  padding: 32rpx;
  margin-top: 16rpx;
}

.records-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.records-title-bar {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 999rpx;
}

.records-title text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.record-card {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-detail {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
  display: block;
}

.record-delete {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 50%;
  margin-left: 24rpx;
  flex-shrink: 0;
}

.record-delete text {
  font-size: 28rpx;
  color: #ff4d4f;
}

.record-delete:active {
  background: #ff4d4f;
}

.record-delete:active text {
  color: #ffffff;
}

/* ---------- 空状态 ---------- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #8c8ea4;
}

/* ---------- Toast 提示 ---------- */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  background: rgba(0, 0, 0, 0.75);
  padding: 28rpx 56rpx;
  border-radius: 32rpx;
  z-index: 9999;
  opacity: 0;
  transition: all 0.25s ease;
}

.toast text {
  color: #ffffff;
  font-size: 28rpx;
  white-space: nowrap;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

/* ---------- 菜品编辑/新增弹窗 ---------- */
.food-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.food-modal-content {
  width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 40rpx;
  overflow: hidden;
}

.food-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx 24rpx;
  border-bottom: 2rpx solid #f0f1f5;
}

.food-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.food-modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f2f5;
  border-radius: 50%;
}

.food-modal-close text {
  font-size: 32rpx;
  color: #555770;
}

.food-modal-body {
  padding: 32rpx 36rpx;
  max-height: 60vh;
}

.form-group {
  margin-bottom: 32rpx;
  min-width: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #555770;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx;
  border: 3rpx solid #e8e9f0;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  background: #ffffff;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx;
  border: 3rpx solid #e8e9f0;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  background: #ffffff;
}

.form-picker.placeholder {
  color: #b4b6c8;
}

.picker-arrow {
  font-size: 24rpx;
  color: #8c8ea4;
}

.food-modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 36rpx 32rpx;
  border-top: 2rpx solid #f0f1f5;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn-cancel {
  background: #f0f2f5;
  color: #555770;
}

.modal-btn-save {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
}

.modal-btn-save:active {
  opacity: 0.85;
}
