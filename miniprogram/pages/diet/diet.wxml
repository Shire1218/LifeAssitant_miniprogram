<view class="page-bg">
  <view class="container">
    <view class="header-card">
      <view class="header-top flex-between">
        <text class="header-title">饮食管理</text>
        <picker mode="date" value="{{selectedDate}}" start="2020-01-01" end="2099-12-31" bindchange="changeDate">
          <view class="date-picker flex-row">
            <text class="date-text">{{selectedDate}}</text>
            <text class="date-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="nutrition-summary">
        <view class="nutrition-item">
          <text class="nutrition-value">{{totalCalories}}</text>
          <text class="nutrition-label">热量(kcal)</text>
        </view>
        <view class="nutrition-item">
          <text class="nutrition-value">{{totalProtein}}</text>
          <text class="nutrition-label">蛋白质(g)</text>
        </view>
        <view class="nutrition-item">
          <text class="nutrition-value">{{totalFat}}</text>
          <text class="nutrition-label">脂肪(g)</text>
        </view>
        <view class="nutrition-item">
          <text class="nutrition-value">{{totalCarbs}}</text>
          <text class="nutrition-label">碳水(g)</text>
        </view>
      </view>
    </view>

    <view class="meal-type-tabs">
      <view wx:for="{{mealTypes}}" wx:key="key"
            class="meal-type-tab {{selectedMealType === item.key ? 'active' : ''}}"
            bindtap="switchMealType" data-meal="{{item.key}}">
        <text class="meal-type-emoji">{{item.emoji}}</text>
        <text class="meal-type-label">{{item.label}}</text>
      </view>
    </view>

    <view class="search-bar">
      <input class="search-input" placeholder="搜索菜品名称或分类..." value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>

    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view wx:for="{{foodCategories}}" wx:key="key"
              class="category-item {{activeCategory === item.key ? 'active' : ''}}"
              bindtap="switchCategory" data-category="{{item.key}}"
              style="{{activeCategory === item.key ? 'background-color: ' + item.color : ''}}">
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-label" style="{{activeCategory === item.key ? 'color: #ffffff' : ''}}">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="food-list">
      <view wx:if="{{filteredFoods.length === 0}}" class="empty-food">
        <text class="empty-food-emoji">🔍</text>
        <text class="empty-food-text">暂无相关菜品</text>
      </view>

      <view wx:for="{{filteredFoods}}" wx:key="id" class="food-card" bindtap="viewFoodDetail" data-food="{{item}}">
        <view class="food-info">
          <text class="food-name">{{item.name}}</text>
          <view class="food-tags">
            <view class="food-tag tag-category">{{item.category}}</view>
            <view class="food-tag tag-calories">{{item.calories}}kcal</view>
          </view>
          <view class="food-nutrition">
            <text class="nutrition-text">P:{{item.protein}}g · F:{{item.fat}}g · C:{{item.carbs}}g</text>
          </view>
        </view>
        <view class="food-price-action">
          <text class="food-price">¥{{item.price}}</text>
          <view class="add-cart-btn" catchtap="addToCart" data-food="{{item}}">
            <text>+</text>
          </view>
        </view>
      </view>
    </view>

    <view class="cart-bar" bindtap="toggleCart">
      <view class="cart-icon-wrapper">
        <text class="cart-icon">🛒</text>
        <view wx:if="{{cartItems.length > 0}}" class="cart-badge">{{cartItems.length}}</view>
      </view>
      <view class="cart-info">
        <text class="cart-total">¥{{cartTotal || 0}}</text>
        <text class="cart-hint">点击查看购物车</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showCart}}" class="cart-mask" bindtap="toggleCart">
    <view class="cart-sheet" catchtap="onModalTap" catchtouchmove="preventMove">
      <view class="cart-header flex-between">
        <text class="cart-title">点餐篮 ({{cartItems.length}})</text>
        <view class="clear-cart-btn" bindtap="clearCart">
          <text>清空</text>
        </view>
      </view>

      <scroll-view class="cart-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:if="{{cartItems.length === 0}}" class="empty-cart">
          <text class="empty-cart-emoji">🛒</text>
          <text class="empty-cart-text">购物车为空</text>
        </view>

        <view wx:for="{{cartItems}}" wx:key="id" class="cart-item">
          <view class="cart-item-info">
            <text class="cart-item-name">{{item.name}}</text>
            <text class="cart-item-portion">{{item.portion}}</text>
          </view>
          <view class="cart-item-action">
            <view class="cart-qty-control">
              <view class="qty-btn" catchtap="removeFromCart" data-id="{{item.id}}">
                <text>−</text>
              </view>
              <text class="qty-num">{{item.quantity}}</text>
              <view class="qty-btn" catchtap="increaseCart" data-id="{{item.id}}">
                <text>+</text>
              </view>
            </view>
            <text class="cart-item-price">¥{{item.price}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="cart-footer">
        <view class="cart-summary">
          <text class="summary-label">合计</text>
          <text class="summary-price">¥{{cartTotal || 0}}</text>
        </view>
        <view class="submit-order-btn" bindtap="submitOrder">确认下单</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showFoodDetail && selectedFood}}" class="detail-mask" bindtap="closeFoodDetail">
    <view class="detail-sheet" catchtap="onModalTap" catchtouchmove="preventMove">
      <view class="detail-handle"></view>
      <view class="detail-header">
        <text class="detail-name">{{selectedFood.name}}</text>
        <view class="detail-category">{{selectedFood.category}}</view>
      </view>

      <view class="detail-nutrition-grid">
        <view class="detail-nutrition-item">
          <text class="detail-nutrition-value">{{selectedFood.calories}}</text>
          <text class="detail-nutrition-label">热量(kcal)</text>
        </view>
        <view class="detail-nutrition-item">
          <text class="detail-nutrition-value">{{selectedFood.protein}}g</text>
          <text class="detail-nutrition-label">蛋白质</text>
        </view>
        <view class="detail-nutrition-item">
          <text class="detail-nutrition-value">{{selectedFood.fat}}g</text>
          <text class="detail-nutrition-label">脂肪</text>
        </view>
        <view class="detail-nutrition-item">
          <text class="detail-nutrition-value">{{selectedFood.carbs}}g</text>
          <text class="detail-nutrition-label">碳水</text>
        </view>
      </view>

      <view class="detail-portion">
        <text class="portion-label">分量</text>
        <view class="portion-control">
          <view class="portion-btn" catchtap="changePortion" data-step="{{-0.5}}">
            <text>−</text>
          </view>
          <text class="portion-value">{{foodPortion}}x</text>
          <view class="portion-btn" catchtap="changePortion" data-step="{{0.5}}">
            <text>+</text>
          </view>
        </view>
      </view>

      <view class="detail-footer">
        <text class="detail-price">¥{{selectedFood.price}}</text>
        <view class="detail-add-btn" catchtap="addToCartFromDetail">加入购物车</view>
      </view>
    </view>
  </view>

  <view class="diet-record-section">
    <view class="section-title">今日饮食记录</view>
    <view wx:if="{{todayDiets.length === 0}}" class="empty-record">
      <text class="empty-record-emoji">📝</text>
      <text class="empty-record-text">今日暂无饮食记录</text>
    </view>

    <view wx:for="{{todayDiets}}" wx:for-item="diet" wx:key="id" class="record-card">
      <view class="record-info">
        <text class="record-detail">{{diet.detail}}</text>
        <view wx:if="{{diet.calories}}" class="record-nutrition">
          <text class="record-cal">{{diet.calories}}kcal</text>
          <text wx:if="{{diet.protein}}" class="record-nut">P:{{diet.protein}}g</text>
          <text wx:if="{{diet.fat}}" class="record-nut">F:{{diet.fat}}g</text>
          <text wx:if="{{diet.carbs}}" class="record-nut">C:{{diet.carbs}}g</text>
        </view>
      </view>
      <view class="record-delete-btn" catchtap="deleteDiet" data-diet="{{diet}}">
        <text>✕</text>
      </view>
    </view>
  </view>
</view>
