.page-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #1677ff;
  flex: 1;
}

.back-btn text {
  font-size: 32rpx;
  font-weight: 600;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  flex: 1;
  justify-content: flex-end;
}

.add-btn text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 300;
}

.meal-tabs {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 12rpx 8rpx;
  margin-bottom: 24rpx;
  justify-content: space-around;
}

.meal-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  transition: all 0.2s;
}

.meal-tab.active {
  background-color: rgba(22, 119, 255, 0.08);
}

.meal-emoji {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.meal-name {
  font-size: 24rpx;
  color: #666666;
}

.meal-tab.active .meal-name {
  color: #1677ff;
  font-weight: 600;
}

.meal-list {
  padding-bottom: 40rpx;
}

.empty-meal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-meal-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-meal-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-meal-desc {
  font-size: 24rpx;
  color: #999999;
}

.meal-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.meal-card:active {
  transform: scale(0.98);
}

.meal-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.meal-name-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.meal-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.meal-action-btn {
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
}

.edit-btn {
  background-color: rgba(22, 119, 255, 0.1);
  color: #1677ff;
}

.delete-btn {
  background-color: rgba(245, 34, 45, 0.1);
  color: #f5222d;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-title-bar {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.modal-close-btn text {
  font-size: 28rpx;
  color: #999999;
}

.modal-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f5f5;
}

.submit-btn {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn:active {
  opacity: 0.85;
}
