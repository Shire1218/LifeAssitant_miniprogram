<view class="page-bg">
  <view class="container">
    <!-- 日历卡片 -->
    <view class="calendar-card">
      <view class="calendar-nav-bar flex-between">
        <view class="nav-btn" bindtap="prevMonth">
          <text>‹</text>
        </view>
        <text class="calendar-title">{{currentMonthText}}</text>
        <view class="nav-btn" bindtap="nextMonth">
          <text>›</text>
        </view>
      </view>
      <view class="calendar-week-header flex-row">
        <text class="week-day week-end">日</text>
        <text class="week-day">一</text>
        <text class="week-day">二</text>
        <text class="week-day">三</text>
        <text class="week-day">四</text>
        <text class="week-day">五</text>
        <text class="week-day week-end">六</text>
      </view>
      <view class="calendar-grid">
        <view wx:for="{{calendarDays}}" wx:key="idx"
              class="cal-cell {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
              bindtap="selectDate" data-date="{{item.date}}">
          <text class="cal-day-num">{{item.day}}</text>
          <view wx:if="{{item.hasSchedule}}" class="cal-dot"></view>
        </view>
      </view>
    </view>

    <!-- 日程列表区域 -->
    <view class="schedule-section">
      <view class="section-header flex-between">
        <view class="section-date">
          <text class="date-main">{{selectedDate}}</text>
          <text class="date-sub">的日程</text>
        </view>
        <view class="add-schedule-btn" bindtap="openAddModal">
          <text>+ 新增</text>
        </view>
      </view>

      <view wx:if="{{daySchedules.length === 0}}" class="empty-schedule">
        <view class="empty-schedule-icon-wrap">
          <text class="empty-schedule-icon">📅</text>
        </view>
        <text class="empty-schedule-title">暂无日程安排</text>
        <text class="empty-schedule-desc">点击「+ 新增」添加今日日程</text>
      </view>

      <view wx:for="{{daySchedules}}" wx:key="id"
            class="schedule-card {{item.completed ? 'completed' : ''}} priority-accent-{{item.priority || 'medium'}}">
        <view class="schedule-left">
          <view class="time-badge">
            <text class="time-start">{{item.startTime}}</text>
            <text wx:if="{{item.endTime}}" class="time-end">{{item.endTime}}</text>
          </view>
        </view>
        <view class="schedule-center flex-1" bindtap="editSchedule" data-schedule="{{item}}">
          <view class="schedule-title-row">
            <text class="schedule-title {{item.completed ? 'completed-title' : ''}}">{{item.title}}</text>
            <view class="priority-tag priority-{{item.priority || 'medium'}}">
              <text class="priority-tag-dot"></text>
              <text class="priority-tag-text">{{item.priority === 'high' ? '高' : item.priority === 'low' ? '低' : '中'}}</text>
            </view>
          </view>
          <view wx:if="{{item.location}}" class="schedule-location">
            <text>📍 {{item.location}}</text>
          </view>
        </view>
        <view class="schedule-right">
          <view class="complete-btn {{item.completed ? 'done' : ''}}" bindtap="toggleComplete" data-schedule="{{item}}">
            <text>{{item.completed ? '✓' : '○'}}</text>
          </view>
          <view class="delete-btn" bindtap="deleteSchedule" data-schedule="{{item}}">
            <text>✕</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 新增/编辑弹窗 -->
  <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="closeAddModal">
    <view class="modal-sheet" catchtap="onModalTap" catchtouchmove="preventMove">
      <view class="modal-handle"></view>
      <view class="modal-title-bar flex-between">
        <text class="modal-title">{{editingSchedule ? '编辑日程' : '新增日程'}}</text>
        <view class="modal-title-actions">
          <view class="modal-submit-btn" bindtap="saveSchedule">{{editingSchedule ? '保存修改' : '添加日程'}}</view>
          <view class="modal-close-btn" bindtap="closeAddModal">
            <text>✕</text>
          </view>
        </view>
      </view>

      <scroll-view class="modal-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="modal-scroll-inner">
          <view class="form-group">
            <text class="form-label">日程标题</text>
            <textarea class="form-input form-title-input" placeholder="输入日程标题" value="{{form.title}}" bindinput="inputTitle" auto-height show-confirm-bar="{{false}}" />
          </view>

          <view class="form-group">
            <text class="form-label">日期</text>
            <picker mode="date" value="{{form.date}}" start="2020-01-01" end="2099-12-31" bindchange="changeDate">
              <view class="form-picker flex-between">
                <text class="{{form.date ? '' : 'placeholder'}}">{{form.date || '选择日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>

          <view class="form-row">
            <view class="form-group flex-1">
              <text class="form-label">开始时间</text>
              <picker mode="time" value="{{form.startTime}}" bindchange="changeStartTime">
                <view class="form-picker flex-between">
                  <text class="{{form.startTime ? '' : 'placeholder'}}">{{form.startTime || '选择时间'}}</text>
                  <text class="picker-arrow">›</text>
                </view>
              </picker>
            </view>
            <view class="form-group flex-1">
              <text class="form-label">结束时间</text>
              <picker mode="time" value="{{form.endTime}}" bindchange="changeEndTime">
                <view class="form-picker flex-between">
                  <text class="{{form.endTime ? '' : 'placeholder'}}">{{form.endTime || '选择时间'}}</text>
                  <text class="picker-arrow">›</text>
                </view>
              </picker>
            </view>
          </view>

          <view class="form-group">
            <text class="form-label">地点（可选）</text>
            <textarea class="form-input form-location-input" placeholder="输入地点" value="{{form.location}}" bindinput="inputLocation" auto-height show-confirm-bar="{{false}}" />
          </view>

          <view class="form-group">
            <text class="form-label">优先级</text>
            <view class="priority-group">
              <view wx:for="{{priorityOptions}}" wx:key="value"
                    class="priority-option {{form.priority === item.value ? 'active' : ''}}"
                    data-priority="{{item.value}}"
                    bindtap="selectPriority">
                <text class="priority-dot" style="background-color: {{item.color}}"></text>
                <text class="priority-label">{{item.label}}</text>
              </view>
            </view>
          </view>

          <view class="form-group">
            <text class="form-label">备注（可选）</text>
            <textarea class="form-textarea" placeholder="添加备注" value="{{form.note}}" bindinput="inputNote" maxlength="200" />
          </view>

          <view class="form-group form-switch-row flex-between">
            <text class="form-label">消息提醒</text>
            <switch checked="{{form.remind}}" bindchange="toggleRemind" color="#1677ff" />
          </view>
        </view>
      </scroll-view>

    </view>
  </view>
</view>
