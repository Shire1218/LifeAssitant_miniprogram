/* ========================================
   日程页面样式
   ======================================== */

page {
  height: auto;
  overflow-y: auto;
}

.page-bg {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---- 日历卡片 ---- */
.calendar-card {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx 20rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.calendar-nav-bar {
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background-color: #f5f6fa;
  transition: all 0.2s;
}

.nav-btn text {
  font-size: 36rpx;
  color: #1677ff;
  font-weight: 700;
}

.nav-btn:active {
  background-color: #e8eaf0;
  transform: scale(0.92);
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.calendar-week-header {
  justify-content: space-around;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f5;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #8c8ca1;
}

.week-day.week-end {
  color: #c8c8d4;
}

.calendar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding-top: 8rpx;
}

.cal-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  position: relative;
  min-height: 80rpx;
}

.cal-cell.empty {
  pointer-events: none;
}

.cal-day-num {
  font-size: 28rpx;
  color: #1a1a2e;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.cal-cell.today .cal-day-num {
  background-color: rgba(22, 119, 255, 0.08);
  color: #1677ff;
  font-weight: 700;
}

.cal-cell.selected .cal-day-num {
  background: linear-gradient(145deg, #1677ff, #4f9cff);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(22, 119, 255, 0.35);
}

.cal-dot {
  width: 10rpx;
  height: 10rpx;
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(245, 158, 11, 0.3);
}

/* ---- 日程区域 ---- */
.schedule-section {
  padding-bottom: 120rpx;
}

.section-header {
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.section-date {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.date-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.date-sub {
  font-size: 26rpx;
  color: #8c8ca1;
  margin-left: 8rpx;
}

.add-schedule-btn {
  padding: 14rpx 32rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4f9cff 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.25);
  transition: all 0.2s;
}

.add-schedule-btn:active {
  opacity: 0.88;
  transform: scale(0.96);
}

/* ---- 空状态 ---- */
.empty-schedule {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-schedule-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f0f2f5, #e8eaf0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty-schedule-icon {
  font-size: 64rpx;
}

.empty-schedule-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a4a68;
  margin-bottom: 12rpx;
}

.empty-schedule-desc {
  font-size: 26rpx;
  color: #8c8ca1;
}

/* ---- 日程卡片 ---- */
.schedule-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.schedule-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
}

.priority-accent-high::before {
  background: linear-gradient(180deg, #ff4d4f, #ff7875);
}

.priority-accent-medium::before {
  background: linear-gradient(180deg, #f59e0b, #fbbf24);
}

.priority-accent-low::before {
  background: linear-gradient(180deg, #00b96b, #34d399);
}

.schedule-card:active {
  transform: scale(0.98);
  background-color: #fafafa;
}

.schedule-card.completed {
  opacity: 0.55;
}

.schedule-left {
  margin-right: 20rpx;
}

.time-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 18rpx;
  background-color: #f5f6fa;
  border-radius: 16rpx;
  min-width: 108rpx;
}

.time-start {
  font-size: 26rpx;
  font-weight: 700;
  color: #1677ff;
}

.time-end {
  font-size: 22rpx;
  color: #8c8ca1;
  margin-top: 4rpx;
}

.schedule-center {
  min-width: 0;
}

.schedule-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.schedule-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.priority-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.priority-tag-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.priority-tag-text {
  font-size: 20rpx;
  font-weight: 600;
}

.priority-high {
  background-color: rgba(255, 77, 79, 0.08);
}

.priority-high .priority-tag-dot {
  background-color: #ff4d4f;
}

.priority-high .priority-tag-text {
  color: #ff4d4f;
}

.priority-medium {
  background-color: rgba(245, 158, 11, 0.08);
}

.priority-medium .priority-tag-dot {
  background-color: #f59e0b;
}

.priority-medium .priority-tag-text {
  color: #f59e0b;
}

.priority-low {
  background-color: rgba(0, 185, 107, 0.08);
}

.priority-low .priority-tag-dot {
  background-color: #00b96b;
}

.priority-low .priority-tag-text {
  color: #00b96b;
}

.completed-title {
  text-decoration: line-through;
  color: #8c8ca1 !important;
}

.schedule-location {
  font-size: 24rpx;
  color: #8c8ca1;
}

.schedule-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-left: 16rpx;
}

.complete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.complete-btn text {
  font-size: 28rpx;
  color: #d9d9d9;
  transition: color 0.2s;
}

.complete-btn.done {
  background: linear-gradient(135deg, #00b96b, #34d399);
  border-color: #00b96b;
  box-shadow: 0 2rpx 8rpx rgba(0, 185, 107, 0.3);
}

.complete-btn.done text {
  color: #ffffff;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(232, 71, 73, 0.06);
  transition: all 0.2s;
}

.delete-btn:active {
  background-color: rgba(232, 71, 73, 0.15);
}

.delete-btn text {
  font-size: 22rpx;
  color: #e84749;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

/* ---- 弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  max-height: 85vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 56rpx;
  height: 8rpx;
  background-color: #e8e8f0;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.modal-title-bar {
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.modal-title-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.modal-submit-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4f9cff 100%);
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.25);
}

.modal-submit-btn:active {
  opacity: 0.88;
  transform: scale(0.96);
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f6fa;
  transition: background-color 0.2s;
}

.modal-close-btn:active {
  background-color: #e8e8f0;
}

.modal-close-btn text {
  font-size: 26rpx;
  color: #8c8ca1;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 32rpx;
}

.modal-scroll-inner {
  width: 100%;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #8c8ca1;
  margin-bottom: 12rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.form-input {
  background-color: #f5f6fa;
  border-radius: 20rpx;
  padding: 30rpx 28rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.form-input:focus {
  border-color: rgba(22, 119, 255, 0.2);
  background-color: #fafafe;
}

.form-title-input {
  min-height: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 24rpx;
}

.form-location-input {
  min-height: 80rpx;
  font-size: 28rpx;
  padding: 24rpx 28rpx;
}

.form-picker {
  background-color: #f5f6fa;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.form-picker:active {
  border-color: rgba(22, 119, 255, 0.2);
  background-color: #fafafe;
}

.form-picker .placeholder {
  color: #c8c8d4;
}

.picker-arrow {
  font-size: 32rpx;
  color: #c8c8d4;
}

.form-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.form-textarea {
  background-color: #f5f6fa;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.form-textarea:focus {
  border-color: rgba(22, 119, 255, 0.2);
  background-color: #fafafe;
}

.form-switch-row {
  margin-bottom: 16rpx;
}

.form-switch-row .form-label {
  margin-bottom: 0;
}

.priority-group {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.priority-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background-color: #f5f6fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.priority-option.active {
  border-color: currentColor;
  background-color: rgba(22, 119, 255, 0.05);
}

.priority-option[data-priority="high"].active {
  border-color: #ff4d4f;
  background-color: rgba(255, 77, 79, 0.06);
}

.priority-option[data-priority="medium"].active {
  border-color: #f59e0b;
  background-color: rgba(245, 158, 11, 0.06);
}

.priority-option[data-priority="low"].active {
  border-color: #00b96b;
  background-color: rgba(0, 185, 107, 0.06);
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.priority-label {
  font-size: 26rpx;
  color: #4a4a68;
  font-weight: 500;
}

.priority-option.active .priority-label {
  color: #1a1a2e;
  font-weight: 600;
}