.calendar-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.calendar-nav-bar {
  margin-bottom: 24rpx;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

.nav-btn text {
  font-size: 36rpx;
  color: #1677ff;
  font-weight: 600;
}

.nav-btn:active {
  background-color: #e8e8e8;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.calendar-week-header {
  justify-content: space-around;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.calendar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding-top: 12rpx;
}

.cal-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  position: relative;
  min-height: 80rpx;
}

.cal-cell.empty {
  pointer-events: none;
}

.cal-day-num {
  font-size: 28rpx;
  color: #333333;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.cal-cell.today .cal-day-num {
  background-color: rgba(22, 119, 255, 0.1);
  color: #1677ff;
  font-weight: 700;
}

.cal-cell.selected .cal-day-num {
  background-color: #1677ff;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.cal-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #faad14;
  border-radius: 50%;
  position: absolute;
  bottom: 10rpx;
}

.schedule-section {
  padding-bottom: 40rpx;
}

.section-header {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-date {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.date-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.date-sub {
  font-size: 26rpx;
  color: #999999;
  margin-left: 8rpx;
}

.add-schedule-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.add-schedule-btn:active {
  opacity: 0.85;
}

.empty-schedule {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-schedule-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-schedule-title {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-schedule-desc {
  font-size: 26rpx;
  color: #999999;
}

.schedule-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.schedule-card:active {
  transform: scale(0.98);
}

.schedule-card.completed {
  opacity: 0.6;
}

.schedule-left {
  margin-right: 20rpx;
}

.time-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  min-width: 100rpx;
}

.time-start {
  font-size: 24rpx;
  font-weight: 600;
  color: #1677ff;
}

.time-end {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.schedule-center {
  min-width: 0;
}

.schedule-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

.schedule-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.priority-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.priority-tag-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.priority-tag-text {
  font-size: 20rpx;
  font-weight: 500;
}

.priority-high {
  background-color: rgba(255, 77, 79, 0.1);
}

.priority-high .priority-tag-dot {
  background-color: #ff4d4f;
}

.priority-high .priority-tag-text {
  color: #ff4d4f;
}

.priority-medium {
  background-color: rgba(250, 173, 20, 0.1);
}

.priority-medium .priority-tag-dot {
  background-color: #faad14;
}

.priority-medium .priority-tag-text {
  color: #faad14;
}

.priority-low {
  background-color: rgba(82, 196, 26, 0.1);
}

.priority-low .priority-tag-dot {
  background-color: #52c41a;
}

.priority-low .priority-tag-text {
  color: #52c41a;
}

.completed-title {
  text-decoration: line-through;
  color: #999999 !important;
}

.schedule-location {
  font-size: 24rpx;
  color: #999999;
}

.schedule-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-left: 16rpx;
}

.complete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
}

.complete-btn text {
  font-size: 28rpx;
  color: #d9d9d9;
}

.complete-btn.done {
  background-color: #52c41a;
  border-color: #52c41a;
}

.complete-btn.done text {
  color: #ffffff;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(245, 34, 45, 0.1);
}

.delete-btn text {
  font-size: 24rpx;
  color: #f5222d;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-title-bar {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-title-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.modal-submit-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.modal-submit-btn:active {
  opacity: 0.85;
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.modal-close-btn text {
  font-size: 28rpx;
  color: #999999;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 32rpx;
}

.modal-scroll-inner {
  width: 100%;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 30rpx 28rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-title-input {
  min-height: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 24rpx;
}

.form-location-input {
  min-height: 80rpx;
  font-size: 30rpx;
  padding: 24rpx 28rpx;
}

.form-picker {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
}

.form-picker .placeholder {
  color: #cccccc;
}

.picker-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.form-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.form-textarea {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-switch-row {
  margin-bottom: 16rpx;
}

.form-switch-row .form-label {
  margin-bottom: 0;
}

.priority-group {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.priority-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.priority-option.active {
  border-color: currentColor;
  background-color: rgba(22, 119, 255, 0.05);
}

.priority-option[data-priority="high"].active {
  border-color: #ff4d4f;
  background-color: rgba(255, 77, 79, 0.08);
}

.priority-option[data-priority="medium"].active {
  border-color: #faad14;
  background-color: rgba(250, 173, 20, 0.08);
}

.priority-option[data-priority="low"].active {
  border-color: #52c41a;
  background-color: rgba(82, 196, 26, 0.08);
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.priority-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.priority-option.active .priority-label {
  color: #333333;
  font-weight: 600;
}
