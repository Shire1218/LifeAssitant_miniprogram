<view class="page-bg">
  <view class="container">
    <view class="summary-card">
      <view class="summary-header flex-between">
        <view class="summary-type-switch">
          <view class="type-btn {{summaryType === 'month' ? 'active' : ''}}" bindtap="switchSummaryType" data-type="month">月</view>
          <view class="type-btn {{summaryType === 'year' ? 'active' : ''}}" bindtap="switchSummaryType" data-type="year">年</view>
        </view>
        <view class="batch-toggle" bindtap="toggleBatchMode">
          <text class="batch-text">{{batchMode ? '退出批量' : '批量管理'}}</text>
        </view>
      </view>
      <view class="summary-period flex-row flex-between">
        <view class="period-picker">
          <picker mode="selector" range="{{yearList}}" value="{{selectedYearIndex}}" bindchange="changeYear">
            <view class="picker-display flex-row">
              <text>{{selectedYear}}年</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view wx:if="{{summaryType === 'month'}}" class="period-picker">
          <picker mode="selector" range="{{monthList}}" value="{{selectedMonth - 1}}" bindchange="changeMonth">
            <view class="picker-display flex-row">
              <text>{{selectedMonth}}月</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="summary-stats">
        <view class="stat-item">
          <text class="stat-label">总收入</text>
          <text class="stat-value income">{{summaryType === 'month' ? monthTotal.income : yearTotal.income}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">总支出</text>
          <text class="stat-value expense">{{summaryType === 'month' ? monthTotal.expense : yearTotal.expense}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">结余</text>
          <text class="stat-value balance">{{summaryType === 'month' ? monthTotal.balance : yearTotal.balance}}</text>
        </view>
      </view>
    </view>

    <view class="bill-list">
      <view wx:if="{{groupedBills.length === 0}}" class="empty-state">
        <view class="empty-icon">💰</view>
        <text class="empty-title">暂无账单记录</text>
        <text class="empty-desc">点击右下角 + 开始记账</text>
      </view>

      <view wx:for="{{groupedBills}}" wx:key="date" class="bill-group">
        <view class="bill-group-header flex-between">
          <text class="group-date">{{item.dateText}}</text>
          <view class="group-summary flex-row">
            <text class="summary-income">收 {{item.dayIncome}}</text>
            <text class="summary-expense">支 {{item.dayExpense}}</text>
          </view>
        </view>

        <view wx:for="{{item.items}}" wx:for-item="bill" wx:key="id"
              class="bill-item {{batchMode ? 'batch-mode' : ''}}"
              bindtap="onBillTap" data-bill="{{bill}}"
              bindlongpress="toggleBatchMode">
          <view wx:if="{{batchMode}}" class="bill-checkbox" catchtap="selectBill" data-id="{{bill.id}}">
            <view class="checkbox-inner {{selectedTags.includes(bill.id) ? 'checked' : ''}}"></view>
          </view>
          <view class="bill-main flex-1">
            <view class="bill-top flex-between">
              <view class="bill-tag-wrap">
                <view class="bill-tag {{bill.type === 'expense' ? 'tag-expense' : 'tag-income'}}">{{bill.tag}}</view>
              </view>
              <view class="bill-amount {{bill.type === 'expense' ? 'amount-expense' : 'amount-income'}}">
                <text>{{bill.type === 'expense' ? '-' : '+'}}{{bill.amount.toFixed(2)}}</text>
              </view>
            </view>
            <view wx:if="{{bill.note}}" class="bill-note">
              <text>{{bill.note}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{batchMode && selectedTags.length > 0}}" class="batch-bar">
      <view class="batch-btn batch-delete" bindtap="batchDelete">删除选中 ({{selectedTags.length}})</view>
    </view>
  </view>

  <view class="fab" style="{{fabStyle}}"
    bindtouchstart="onFabTouchStart"
    bindtouchmove="onFabTouchMove"
    bindtouchend="onFabTouchEnd">
    <text class="fab-icon">+</text>
  </view>

  <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="closeAddModal">
    <view class="modal-sheet" catchtap="onModalTap" catchtouchmove="preventMove">
      <view class="modal-handle"></view>
      <view class="modal-title-bar flex-between">
        <text class="modal-title">{{editingBill ? '编辑账单' : '新增账单'}}</text>
        <view class="modal-close-btn" bindtap="closeAddModal">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-scroll">
        <view class="type-switcher">
          <view class="switch-btn {{form.type === 'expense' ? 'active expense' : ''}}" bindtap="switchType" data-type="expense">支出</view>
          <view class="switch-btn {{form.type === 'income' ? 'active income' : ''}}" bindtap="switchType" data-type="income">收入</view>
        </view>

        <view class="tag-grid">
          <view wx:for="{{form.type === 'expense' ? expenseTags : incomeTags}}" wx:key="*this"
                class="tag-item {{form.tag === item ? 'active' : ''}}"
                bindtap="selectTag" data-tag="{{item}}">
            <text>{{item}}</text>
          </view>
        </view>

        <view class="amount-section">
          <text class="amount-symbol">¥</text>
          <input class="amount-input" type="digit" placeholder="0.00" value="{{form.amount}}" bindinput="inputAmount" />
        </view>

        <view class="form-section">
          <view class="form-row">
            <text class="form-label">日期</text>
            <picker mode="date" value="{{form.date}}" start="2020-01-01" end="2099-12-31" bindchange="changeDate">
              <view class="form-picker flex-between">
                <text class="{{form.date ? '' : 'placeholder'}}">{{form.date || '选择日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>

          <view class="form-row">
            <text class="form-label">备注</text>
            <textarea class="form-textarea" placeholder="添加备注..." value="{{form.note}}" bindinput="inputNote" maxlength="200" />
          </view>
        </view>
      </view>

      <view class="modal-footer">
        <view class="submit-btn" bindtap="saveBill">{{editingBill ? '保存修改' : '添加账单'}}</view>
      </view>
    </view>
  </view>
</view>
