.summary-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.summary-header {
  margin-bottom: 24rpx;
}

.summary-type-switch {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}

.type-btn {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.15);
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.2s;
}

.type-btn.active {
  background-color: rgba(255, 255, 255, 0.35);
  color: #ffffff;
  font-weight: 700;
}

.summary-period {
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.period-picker {
  flex: 1;
}

.picker-display {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.12);
  align-items: center;
  justify-content: space-between;
}

.picker-display text {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.picker-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.batch-toggle {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.batch-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.summary-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.stat-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-entry-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.stat-entry-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stat-label {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 0;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
}

.stat-value.income {
  color: #b7f5b7;
}

.stat-value.expense {
  color: #ffb3b3;
}

.stat-value.balance {
  color: #ffffff;
}

.bill-list {
  padding-bottom: 240rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

.bill-group {
  margin-bottom: 32rpx;
}

.bill-group-header {
  padding: 0 12rpx;
  margin-bottom: 16rpx;
}

.group-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.group-summary {
  gap: 24rpx;
}

.summary-income {
  font-size: 28rpx;
  font-weight: 600;
  color: #52c41a;
}

.summary-expense {
  font-size: 28rpx;
  font-weight: 600;
  color: #f5222d;
}

.bill-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s;
}

.bill-item:active {
  transform: scale(0.98);
  background-color: #f8f8f8;
}

.bill-checkbox {
  margin-right: 20rpx;
}

.checkbox-inner {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 50%;
  transition: all 0.2s;
}

.checkbox-inner.checked {
  background-color: #1677ff;
  border-color: #1677ff;
  position: relative;
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 12rpx;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid #ffffff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.bill-main {
  min-width: 0;
}

.bill-top {
  margin-bottom: 8rpx;
}

.bill-tag-wrap {
  display: flex;
  align-items: center;
}

.bill-tag {
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.bill-tag.tag-expense {
  background-color: rgba(245, 34, 45, 0.1);
  color: #f5222d;
}

.bill-tag.tag-income {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.bill-amount {
  font-size: 40rpx;
  font-weight: 800;
}

.bill-amount.amount-expense {
  color: #f5222d;
}

.bill-amount.amount-income {
  color: #52c41a;
}

.bill-note {
  font-size: 28rpx;
  font-weight: 500;
  color: #999999;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 300rpx;
  width: 120rpx;
  height: 120rpx;
  background: white;
  border-radius: 60%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(22, 119, 255, 0.4);
  z-index: 100;
  transition: box-shadow 0.2s;
}

.fab:active {
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.5);
}

.fab-icon {
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 200;
}

.batch-btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.batch-delete {
  background-color: #f5222d;
  color: #ffffff;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-title-bar {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #333333;
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.modal-close-btn text {
  font-size: 28rpx;
  color: #999999;
}

.modal-scroll {
  flex: 1;
  height: 0;
  padding: 32rpx;
}

.type-switcher {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.switch-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 35rpx;
  font-weight: 700;
  color: #666666;
  transition: all 0.25s;
}

.switch-btn.active {
  background-color: #ffffff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.switch-btn.active.expense {
  color: #f5222d;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

.switch-btn.active.income {
  color: #52c41a;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tag-item {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  font-size: 30rpx;
  font-weight: 600;
  color: #666666;
  transition: all 0.2s;
}

.tag-item.active {
  background-color: rgba(22, 119, 255, 0.1);
  color: #1677ff;
  font-weight: 600;
}

.amount-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 32rpx;
  min-height: 80rpx;
}

.amount-symbol {
  font-size: 56rpx;
  color: #333333;
  font-weight: 700;
  line-height: 1;
  flex-shrink: 0;
}

.amount-input {
  flex: 1;
  font-size: 64rpx;
  font-weight: 800;
  color: #333333;
  margin-left: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.form-section {
  margin-bottom: 16rpx;
}

.form-row {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.form-picker {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}

.form-picker .placeholder {
  color: #cccccc;
}

.picker-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.form-textarea {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  font-weight: 500;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f5f5;
  background-color: #ffffff;
  flex-shrink: 0;
}

.submit-btn {
  width: 100%;
  padding: 32rpx 32rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.submit-btn:active {
  opacity: 0.85;
}
