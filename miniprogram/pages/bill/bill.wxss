/* ========================================
   账本页面样式
   ======================================== */

/* ---- 汇总卡片 ---- */
.summary-card {
  background: linear-gradient(145deg, #1677ff 0%, #3d8bff 40%, #6aabff 100%);
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(22, 119, 255, 0.3);
}

.summary-card-bg-decor {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.summary-header {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.summary-type-switch {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}

.type-btn {
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.15);
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.65);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(4rpx);
}

.type-btn.active {
  background-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.summary-period {
  margin-bottom: 28rpx;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.period-picker {
  flex: 1;
}

.picker-display {
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.12);
  align-items: center;
  justify-content: space-between;
}

.picker-display text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.picker-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
}

.batch-toggle {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(4rpx);
}

.batch-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.summary-stats {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.18);
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-divider {
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.15);
  margin: 4rpx 0;
}

.stat-label {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 0;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.5rpx;
}

.stat-value.income {
  color: #b8f5d0;
}

.stat-value.expense {
  color: #ffc4c4;
}

.stat-value.balance {
  color: #ffffff;
}

/* ---- 账单列表 ---- */
.bill-list {
  padding-bottom: 240rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 0 120rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f0f2f5, #e8eaf0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a4a68;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8c8ca1;
}

.bill-group {
  margin-bottom: 32rpx;
}

.bill-group-header {
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}

.group-date-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.group-date {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.group-summary {
  gap: 12rpx;
  align-items: center;
}

.summary-income {
  font-size: 24rpx;
  font-weight: 600;
  color: #00b96b;
}

.summary-divider-dot {
  font-size: 20rpx;
  color: #c8c8d4;
}

.summary-expense {
  font-size: 24rpx;
  font-weight: 600;
  color: #e84749;
}

/* ---- 账单条目 ---- */
.bill-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.bill-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  transition: background-color 0.2s;
}

.bill-expense::before {
  background: linear-gradient(180deg, #e84749, #ff6b6b);
}

.bill-income::before {
  background: linear-gradient(180deg, #00b96b, #34d399);
}

.bill-item:active {
  transform: scale(0.98);
  background-color: #fafafa;
}

.bill-checkbox {
  margin-right: 20rpx;
}

.checkbox-inner {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 12rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.checkbox-inner.checked {
  background: linear-gradient(135deg, #1677ff, #4f9cff);
  border-color: #1677ff;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.3);
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 12rpx;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid #ffffff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.bill-main {
  min-width: 0;
}

.bill-top {
  margin-bottom: 6rpx;
}

.bill-tag-wrap {
  display: flex;
  align-items: center;
}

.bill-tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.bill-tag.tag-expense {
  background-color: rgba(232, 71, 73, 0.08);
  color: #e84749;
}

.bill-tag.tag-income {
  background-color: rgba(0, 185, 107, 0.08);
  color: #00b96b;
}

.bill-amount {
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}

.bill-amount.amount-expense {
  color: #e84749;
}

.bill-amount.amount-income {
  color: #00b96b;
}

.bill-note {
  font-size: 26rpx;
  font-weight: 400;
  color: #8c8ca1;
  margin-top: 4rpx;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

/* ---- 浮动按钮 ---- */
.fab {
  position: fixed;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(145deg, #1677ff 0%, #4f9cff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(22, 119, 255, 0.4);
  z-index: 100;
  transition: box-shadow 0.2s, transform 0.2s;
}

.fab:active {
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.5);
  transform: scale(0.92);
}

.fab-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
  pointer-events: none;
}

/* ---- 批量操作栏 ---- */
.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 200;
}

.batch-btn {
  width: 100%;
  padding: 26rpx 0;
  border-radius: 20rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.batch-delete {
  background: linear-gradient(135deg, #e84749 0%, #ff6b6b 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(232, 71, 73, 0.25);
}

/* ---- 弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  max-height: 85vh;
  height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 56rpx;
  height: 8rpx;
  background-color: #e8e8f0;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.modal-title-bar {
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f6fa;
  transition: background-color 0.2s;
}

.modal-close-btn:active {
  background-color: #e8e8f0;
}

.modal-close-btn text {
  font-size: 26rpx;
  color: #8c8ca1;
}

.modal-scroll {
  flex: 1;
  height: 0;
  padding: 32rpx;
}

.type-switcher {
  display: flex;
  background-color: #f5f6fa;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}

.switch-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #8c8ca1;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.switch-btn.active {
  background-color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.switch-btn.active.expense {
  color: #e84749;
}

.switch-btn.active.income {
  color: #00b96b;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tag-item {
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  background-color: #f5f6fa;
  font-size: 28rpx;
  font-weight: 600;
  color: #4a4a68;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
}

.tag-item.active {
  background-color: rgba(22, 119, 255, 0.08);
  color: #1677ff;
  font-weight: 700;
  border-color: rgba(22, 119, 255, 0.2);
}

.amount-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 2rpx solid #f0f0f5;
  margin-bottom: 32rpx;
  min-height: 80rpx;
}

.amount-symbol {
  font-size: 52rpx;
  color: #1a1a2e;
  font-weight: 800;
  line-height: 1;
  flex-shrink: 0;
}

.amount-input {
  flex: 1;
  font-size: 60rpx;
  font-weight: 800;
  color: #1a1a2e;
  margin-left: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.form-section {
  margin-bottom: 16rpx;
}

.form-row {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #8c8ca1;
  margin-bottom: 12rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.form-picker {
  background-color: #f5f6fa;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.form-picker:active {
  border-color: rgba(22, 119, 255, 0.2);
  background-color: #fafafe;
}

.form-picker .placeholder {
  color: #c8c8d4;
}

.picker-arrow {
  font-size: 32rpx;
  color: #c8c8d4;
}

.form-textarea {
  background-color: #f5f6fa;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.form-textarea:focus {
  border-color: rgba(22, 119, 255, 0.2);
  background-color: #fafafe;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f5;
  background-color: #ffffff;
  flex-shrink: 0;
}

.submit-btn {
  width: 100%;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #1677ff 0%, #4f9cff 100%);
  color: #ffffff;
  border-radius: 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
  transition: all 0.2s;
}

.submit-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}
