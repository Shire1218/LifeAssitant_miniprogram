.page-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.header-count {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  padding: 8rpx 20rpx;
  background-color: rgba(22, 119, 255, 0.08);
  border-radius: 20rpx;
}

.count-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1677ff;
}

.count-label {
  font-size: 22rpx;
  color: #1677ff;
  margin-left: 4rpx;
}

.note-list {
  padding-bottom: 160rpx;
}

.empty-note {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-note-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-note-title {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-note-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.empty-note-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-note-btn:active {
  opacity: 0.85;
}

.note-card {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.note-card:active {
  transform: scale(0.98);
}

.note-card-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.note-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-card-abstract {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.note-card-footer {
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

.note-card-time {
  font-size: 22rpx;
  color: #999999;
}

.note-card-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.note-action-btn {
  font-size: 22rpx;
  color: #1677ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background-color: rgba(22, 119, 255, 0.1);
}

.note-action-btn.danger {
  color: #f5222d;
  background-color: rgba(245, 34, 45, 0.1);
}

.note-card-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(22, 119, 255, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.editor-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  z-index: 400;
  display: flex;
  flex-direction: column;
}

.editor-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.editor-header {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 88rpx;
}

.editor-cancel {
  font-size: 28rpx;
  color: #999999;
}

.editor-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.editor-save {
  font-size: 28rpx;
  font-weight: 600;
}

.editor-title-input {
  padding: 24rpx;
  font-size: 36rpx;
  font-weight: 600;
  border-bottom: 1rpx solid #f5f5f5;
}

.editor-toolbar {
  padding: 12rpx 16rpx;
  overflow-x: auto;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fafafa;
  flex-shrink: 0;
}

.toolbar-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333333;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.toolbar-btn:active {
  background-color: #f0f0f0;
}

.toolbar-divider {
  width: 1rpx;
  height: 40rpx;
  background-color: #e8e8e8;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.color-btn {
  padding: 0;
}

.color-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}

.editor-content {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}
