<view class="page-bg">
  <view class="container">
    <view class="page-header">
      <text class="page-title">生活随笔</text>
      <view class="header-count">
        <text class="count-num">{{notes.length}}</text>
        <text class="count-label">篇</text>
      </view>
    </view>

    <view class="note-list">
      <view wx:if="{{notes.length === 0}}" class="empty-note">
        <view class="empty-note-icon">✍️</view>
        <text class="empty-note-title">还没有随笔</text>
        <text class="empty-note-desc">记录生活中的每一个精彩瞬间</text>
        <view class="empty-note-btn" bindtap="openAddModal">开始写作</view>
      </view>

      <view wx:for="{{notes}}" wx:key="id" class="note-card" bindtap="viewNoteDetail" data-note="{{item}}">
        <view class="note-card-main">
          <text class="note-card-title">{{item.title}}</text>
          <text class="note-card-abstract">{{item.plainText}}</text>
          <view class="note-card-footer flex-between">
            <text class="note-card-time">{{item.dateStr}}</text>
            <view class="note-card-actions" catchtap="">
              <view class="note-action-btn" bindtap="editNote" data-note="{{item}}">编辑</view>
              <view class="note-action-btn danger" bindtap="deleteNote" data-note="{{item}}">删除</view>
            </view>
          </view>
        </view>
        <image wx:if="{{item.firstImage}}" src="{{item.firstImage}}" mode="aspectFill" class="note-card-cover" />
      </view>
    </view>

    <view class="fab" bindtap="openAddModal">
      <text class="fab-icon">+</text>
    </view>
  </view>

  <view wx:if="{{showAddModal}}" class="editor-mask" catchtap="closeAddModal">
    <view class="editor-container" catchtap="">
      <view class="editor-header flex-between">
        <view class="editor-cancel" bindtap="closeAddModal">取消</view>
        <text class="editor-title-text">写随笔</text>
        <view class="editor-save text-primary" bindtap="saveNote">保存</view>
      </view>

      <input class="editor-title-input" placeholder="输入标题..." value="{{noteTitle}}" bindinput="inputTitle" />

      <view class="editor-toolbar flex-row">
        <view class="toolbar-btn" bindtap="formatBold"><text style="font-weight: bold;">B</text></view>
        <view class="toolbar-btn" bindtap="formatItalic"><text style="font-style: italic;">I</text></view>
        <view class="toolbar-btn" bindtap="formatUnderline"><text style="text-decoration: underline;">U</text></view>
        <view class="toolbar-divider"></view>
        <view class="toolbar-btn" bindtap="formatHeader" data-value="1">H1</view>
        <view class="toolbar-btn" bindtap="formatHeader" data-value="2">H2</view>
        <view class="toolbar-btn" bindtap="formatHeader" data-value="3">H3</view>
        <view class="toolbar-divider"></view>
        <view class="toolbar-btn" bindtap="formatAlign" data-value="left">≡</view>
        <view class="toolbar-btn" bindtap="formatAlign" data-value="center">≡</view>
        <view class="toolbar-btn" bindtap="formatAlign" data-value="right">≡</view>
        <view class="toolbar-divider"></view>
        <view class="toolbar-btn" bindtap="formatList">☰</view>
        <view class="toolbar-btn" bindtap="formatOrderedList">①</view>
        <view class="toolbar-divider"></view>
        <view class="toolbar-btn color-btn" bindtap="formatColor" data-color="#f5222d">
          <view class="color-dot" style="background: #f5222d;"></view>
        </view>
        <view class="toolbar-btn color-btn" bindtap="formatColor" data-color="#1677ff">
          <view class="color-dot" style="background: #1677ff;"></view>
        </view>
        <view class="toolbar-btn color-btn" bindtap="formatColor" data-color="#52c41a">
          <view class="color-dot" style="background: #52c41a;"></view>
        </view>
        <view class="toolbar-divider"></view>
        <view class="toolbar-btn" bindtap="insertImage">🖼</view>
      </view>

      <editor class="editor-content" id="editor"
              placeholder="开始记录你的生活..."
              show-img-size show-img-resize show-img-toolbar
              bindready="editorReady"
              bindstatuschange="onEditorChange">
      </editor>
    </view>
  </view>
</view>
