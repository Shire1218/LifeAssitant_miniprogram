<view class="page-bg">
  <view class="container" wx:if="{{note}}">
    <view class="detail-header flex-between">
      <view class="back-btn" bindtap="goBack">← 返回</view>
      <text class="text-gray text-small">{{note.dateStr}} {{note.timeStr}}</text>
    </view>

    <view class="card detail-card">
      <text class="detail-title">{{note.title}}</text>
      <view class="divider"></view>
      <view class="detail-content">
        <rich-text nodes="{{contentHtml}}"></rich-text>
      </view>
    </view>
  </view>
</view>
